# =============================================================================
# RobotOS — .gitignore
# =============================================================================
# West workspace metadata (auto-generated by `west init`)
/.west/

# West-fetched repos (reproduced by `west update` from west.yml)
/zephyr/
/modules/

# CMake / Ninja build output (reproduced by `west build`)
/build/
RobotOS_v1.0/build/

# Per-machine VS Code IntelliSense config (auto-generated by C/C++ extension)
.vscode/c_cpp_properties.json

# Python
__pycache__/
*.pyc
*.pyo
.Python

# OS generated
.DS_Store
Thumbs.db
